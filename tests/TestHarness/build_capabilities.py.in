"""Build-time capabilities generated by CMake for TestHarness."""

_NODEOP_WASM_CAPABILITIES = {
    "supports_oc": @SYSIO_SUPPORTS_SYS_VM_OC_PY@,
    "runtimes": [@SYSIO_TEST_WASM_RUNTIMES_PY@],
    "default_runtime": @SYSIO_DEFAULT_WASM_RUNTIME_PY@,
}

def nodeopWasmCapabilities():
    """Return CMake-generated nodeop WASM capabilities for integration tests."""
    return {
        "supports_oc": _NODEOP_WASM_CAPABILITIES["supports_oc"],
        "runtimes": list(_NODEOP_WASM_CAPABILITIES["runtimes"]),
        "default_runtime": _NODEOP_WASM_CAPABILITIES["default_runtime"],
    }

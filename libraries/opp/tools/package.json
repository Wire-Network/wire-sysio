{
  "name": "@wireio/opp-tools-project",
  "private": true,
  "scripts": {
    "compile": "tsc -b tsconfig.json",
    "compile:watch": "tsc -b tsconfig.json -w --preserveWatchOutput",
    "build": "pnpm run compile",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "pnpm run build && jest",
    "clean": "./scripts/clean.sh && pnpm -r run clean"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "25.5.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "resolutions": {
    "lodash": "4.17.21",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "@protobuf-ts/plugin>typescript": "3.9.10"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  }
}

{
  "extends": "../etc/tsconfig/tsconfig.base.jest.json",
  "compilerOptions": {
    "rootDir": "tests",
    "outDir": "lib/test-cjs",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "composite": true,
    "incremental": true,
    "paths": {
      "@wireio/protoc-gen-solana": ["./src"],
      "@wireio/protoc-gen-solana/*": ["./src/*"]
    }
  },
  "references": [
    { "path": "./tsconfig.cjs.json" }
  ],
  "include": ["tests"]
}

{
  "compilerOptions": {
		"module": "ESNext",
		"target": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
    "declaration": true,
    "declarationMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
		"skipDefaultLibCheck": true,
		"sourceMap": true,
		"outDir": "./lib/esm",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}

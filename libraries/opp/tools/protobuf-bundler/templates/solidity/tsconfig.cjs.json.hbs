{
	"compilerOptions": {
		"target": "ESNext",
		"moduleDetection": "force",
		"module": "commonjs",
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"declaration": true,
		"declarationMap": true,
		"strict": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"skipDefaultLibCheck": true,
		"sourceMap": true,
		"outDir": "./lib/cjs",
		"rootDir": "./src"
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
